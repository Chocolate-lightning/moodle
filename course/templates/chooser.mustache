{{!
    @template core_course/chooser

    Chooser dialog template.

    Example context (json):
    {
        "title": "Chooser title",
        "options": {
            "label": "Option name",
            "description": "Option description",
            "urls": {
                "addoption": "http://addoptionurl.com"
            },
            "icon": "<img class='icon' src='http://urltooptionicon'>"
        }
    }
}}
<div data-region="carousel" class="carousel slide">
    <div class="carousel-inner">
        <div class="carousel-item p-4 active">
            <ul class="nav nav-tabs" id="TODO" role="tablist">
                <li class="nav-item">
                    <a class="nav-link" id="starred-tab" data-toggle="tab" href="#starred" role="tab" aria-controls="starred" aria-selected="false">Starred</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" id="recommended-tab" data-toggle="tab" href="#recommended" role="tab" aria-controls="recommended" aria-selected="true">Recommended</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="all-tab" data-toggle="tab" href="#all" role="tab" aria-controls="all" aria-selected="false">Modules</a>
                </li>
            </ul>
            <div class="tab-content" id="myTabContent">
                <div class="tab-pane fade" id="starred" role="tabpanel" aria-labelledby="starred-tab">
                    <div class="modchoosercontainer" data-region="chooser-container" tabindex="0" role="grid" aria-rowcount="1">
                        <div class="optionscontainer d-flex flex-wrap mw-100 position-relative" role="row" data-region="chooser-options-container">
                            {{#favourites}}
                                {{>core_course/chooser_item}}
                            {{/favourites}}
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade show active" id="recommended" role="tabpanel" aria-labelledby="recommended-tab">
                    <div class="modchoosercontainer" data-region="chooser-container" tabindex="0" role="grid" aria-rowcount="1">
                        <div class="optionscontainer d-flex flex-wrap mw-100 position-relative" role="row" data-region="chooser-options-container">
                            {{#recommended}}
                                {{>core_course/chooser_item}}
                            {{/recommended}}
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="all" role="tabpanel" aria-labelledby="all-tab">
                    <div class="modchoosercontainer" data-region="chooser-container" tabindex="0" role="grid" aria-rowcount="1">
                        <div class="optionscontainer d-flex flex-wrap mw-100 position-relative" role="row" data-region="chooser-options-container">
                            {{#allmodules}}
                                {{>core_course/chooser_item}}
                            {{/allmodules}}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="carousel-item" data-region="help"></div>
    </div>
</div>
