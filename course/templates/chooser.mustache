{{!
    @template core_course/chooser

    Chooser dialog template.

    Example context (json):
    {
        "title": "Chooser title",
        "options": {
            "label": "Option name",
            "description": "Option description",
            "urls": {
                "addoption": "http://addoptionurl.com"
            },
            "icon": "<img class='icon' src='http://urltooptionicon'>"
        }
    }
}}
<div>
    <input type="text"
           data-action="searchme"
           class="form-control form-control-lg"
           placeholder="TODO"
    >
</div>
<div data-region="carousel" class="carousel slide">
    <div class="carousel-inner" aria-live="polite">
        <div class="carousel-item p-4 active" data-region="modules">
            <ul class="nav nav-tabs" id="activities-{{uniqid}}" role="tablist">
                <li class="nav-item">
                    <a class="nav-link {{#favouritesFirst}}active{{/favouritesFirst}} {{^favourites}}d-none{{/favourites}}"
                       id="starred-tab-{{uniqid}}"
                       data-toggle="tab"
                       href="#starred"
                       role="tab"
                       aria-controls="starred"
                       aria-selected="{{#favouritesFirst}}true{{/favouritesFirst}}{{^favouritesFirst}}false{{/favouritesFirst}}">
                        {{#str}}favourites{{/str}}
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{#recommendedFirst}}active{{/recommendedFirst}} {{^recommended}}d-none{{/recommended}}"
                       id="recommended-tab-{{uniqid}}"
                       data-toggle="tab"
                       href="#recommended"
                       role="tab"
                       aria-controls="recommended"
                       aria-selected="{{#recommendedFirst}}true{{/recommendedFirst}}{{^recommendedFirst}}false{{/recommendedFirst}}">
                        {{#str}}recommended{{/str}}
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{#fallback}}active{{/fallback}}"
                       id="all-tab-{{uniqid}}"
                       data-toggle="tab"
                       href="#all"
                       role="tab"
                       aria-controls="all"
                       aria-selected="{{#fallback}}true{{/fallback}}{{^fallback}}false{{/fallback}}">
                        {{#str}}managemodules{{/str}}
                    </a>
                </li>
            </ul>
            <div class="tab-content" id="tabbed-activities-{{uniqid}}">
                <div class="tab-pane fade {{#favouritesFirst}}show active{{/favouritesFirst}}" id="starred" role="tabpanel" aria-labelledby="starred-tab-{{uniqid}}">
                    <div class="modchoosercontainer" data-region="chooser-container" tabindex="0" role="grid" aria-rowcount="1" aria-label="{{#str}} activitymodules {{/str}}">
                        <div class="optionscontainer d-flex flex-wrap mw-100 position-relative" role="row" data-region="chooser-options-container">
                            {{#favourites}}
                                {{>core_course/chooser_item}}
                            {{/favourites}}
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade {{#recommendedFirst}}show active{{/recommendedFirst}}" id="recommended" role="tabpanel" aria-labelledby="recommended-tab-{{uniqid}}">
                    <div class="modchoosercontainer" data-region="chooser-container" tabindex="0" role="grid" aria-rowcount="1" aria-label="{{#str}} activitymodules {{/str}}">
                        <div class="optionscontainer d-flex flex-wrap mw-100 position-relative" role="row" data-region="chooser-options-container">
                            {{#recommended}}
                                {{>core_course/chooser_item}}
                            {{/recommended}}
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade {{#fallback}}show active{{/fallback}}" id="all" role="tabpanel" aria-labelledby="all-tab-{{uniqid}}">
                    <div class="modchoosercontainer" data-region="chooser-container" tabindex="0" role="grid" aria-rowcount="1" aria-label="{{#str}} activitymodules {{/str}}">
                        <div class="optionscontainer d-flex flex-wrap mw-100 position-relative" role="row" data-region="chooser-options-container">
                            {{#default}}
                                {{>core_course/chooser_item}}
                            {{/default}}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="carousel-item" data-region="help"></div>
    </div>
</div>
