{{!
    @template core_course/chooser_favourites

    Chooser favourite template partial.

    Example context (json):
    {
    }
}}
{{#enabled}}
    <div class="w-100 d-flex justify-content-between">
    {{#installed}}
        {{#advanced}}
            <a href="{{test}}/@{{user}}?return={{return}}" target="_self">Or, browse & use content from <img src="{{{img}}}"></a>
        {{/advanced}}
        {{^advanced}}
            <button class="btn btn-secondary d-block w-50 mr-auto" data-action="show-moodlenet" data-courseid="{{courseID}}" data-sectionID="{{sectionID}}">
                <p class="d-block mb-0 pull-left">Or, browse & use content from</p>
                <img class="d-block w-25 pull-left" src="{{{img}}}">
            </button>
        {{/advanced}}
    {{/installed}}
    {{^installed}}
        <a href="{{generic}}">Or, browse & use content from  <img src="{{{img}}}"></a>
    {{/installed}}
    </div>
{{/enabled}}
