{{!
    @template core_course/single_section_page

    This template renders a course format section.

    Example context (json):
    {
        "clipboard": "",
        "startsection": "<ul class='topics'>",
        "section": "Course format render_section() HTML",
        "endsection": "</ul>",
        "linkprev": "<a class='dimmed_text' href='/course/view.php?id=5&amp;section=1'><span class='larrow'>◀︎</span>Topic 1</a>",
        "linknext": "<a href='/course/view.php?id=5&amp;section=3'>Topic 3<span class='rarrow'>▶︎</span></a>",
        "classes": "dimmed_text",
        "sectionname": "Topic 2",
        "coursesection": "Course format render_section() HTML",
        "navselection": "<div class='jumpmenu'>
                            <form method='post' action='/course/jumpto.php' class='form-inline' id='sectionmenu'>
                                <input type='hidden' name='sesskey' value='<unique>'>
                                <select  id='url_select<unique>' class='custom-select jumpmenu' name='jump'>
                                            <option value=' selected>Jump to...</option>
                                            <option value='/course/view.php?id=5' >Main course page</option>
                                            <option value='/course/view.php?id=5&amp;section=1' >Topic 1</option>
                                            <option value='/course/view.php?id=5&amp;section=3' >Topic 3</option>
                                </select>
                                    <noscript>
                                        <input type='submit' class='btn btn-secondary' value='Go'>
                                    </noscript>
                            </form>
                        </div>"
    }
}}
{{{clipboard}}}
{{{startsection}}}
    {{{section}}}
{{{endsection}}}
<div class="single-section">
    <div class="section-navigation navigationtitle">
        <span class="mdl-left">{{{linkprev}}}</span>
        <span class="mdl-right">{{{linknext}}}</span>
        <h3 class="sectionname {{{classes}}}">
            <span>{{{sectionname}}}</span>
        </h3>
    </div>

    {{{startsection}}}
        {{{coursesection}}}
    {{{endsection}}}
    <div class="section-navigation mdl-bottom">
        <span class="mdl-left">{{{linkprev}}}</span>
        <span class="mdl-right">{{{linknext}}}</span>
        <div class="mdl-align">{{{navselection}}}</div>
    </div>
</div>
