{{!
    @template core_course/section_summary

    This template renders a course format section.

    Example context (json):
    {
        "sectionid": "8",
        "style": "hidden",
        "sectionname": "Topic 1",
        "title": "Topic 1",
        "availability": "<div class='section_availability'><span class='badge badge-info'>Hidden from students</span></div>",
        "summary": "<div class='no-overflow'>Here is a great topic!</div>",
        "activitysummary": "<div class='section-summary-activities mdl-right'><span class='activity-count'>Assignments: 2</span></div>",
    }
}}
<li id="section-{{sectionid}}" class="section main section-summary clearfix {{{style}}}" role="region" aria-label="{{{sectionname}}}">
    <div class="left side"></div>
    <div class="right side"></div>
    <div class="content">
        <h3 class="section-title">
            {{{title}}}
        </h3>
        {{{availability}}}
        <div class="summarytext">
            {{{summary}}}
        </div>
        {{{activitysummary}}}
    </div>
</li>
