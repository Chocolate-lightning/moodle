{{!
    @template core_course/section_hidden

    This template renders the hidden section.

    Example context (json):
    {
        "nocoursesimgurl": "https://moodlesite/theme/image.php/boost/block_recentlyaccessedcourses/1535727318/courses"
    }
}}
<li id="section-{{sectionno}}" class="section main clearfix hidden dab">
    <div class="left side"></div>
    <div class="right side"></div>
    <div class="content">
        {{{strnotavailable}}}
    </div>
</li>
