{{!
    @template block_myoverview/main

    This template renders the main content area for the myoverview block.

    Example context (json):
    {}
}}

<div id="block-myoverview-{{uniqid}}" class="block-myoverview block-cards" data-region="myoverview" role="navigation">

            <div data-region="filter" class="d-flex align-items-center flex-wrap" aria-label="{{#str}} aria:controls, block_myoverview {{/str}}">
                {{> block_myoverview/nav-grouping-selector }}

                {{> block_myoverview/nav-sort-selector }}
                {{#displaydropdown}}
                    {{> block_myoverview/nav-display-selector }}
                {{/displaydropdown}}
            </div>

            <div class="searchbar input-group w-50" role="search">
                <label for="searchinput">
                    <span class="sr-only">{{#str}} searchcourses, tool_moodlenet {{/str}}</span>
                </label>
                <input type="text"
                       data-region="search-input"
                       id="searchinput"
                       class="form-control form-control-lg searchinput border-right-0 px-3 py-2"
                       placeholder="{{#str}} search, core {{/str}}"
                       name="search"
                       autocomplete="off"
                >
                <div class="searchbar-append d-flex border border-secondary border-left-0 px-3 py-2">
                    <div data-region="search-icon">
                        {{#pix}} a/search, core {{/pix}}
                    </div>
                    <div class="clear d-none">
                        <button class="btn p-0" data-region="clear-icon">
                            <span class="d-flex" aria-hidden="true">{{#pix}} e/cancel, core {{/pix}}</span>
                            <span class="sr-only">{{#str}} clearsearch, tool_moodlenet {{/str}}</span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="my-4" data-region="myoverview-courses" aria-live="polite"></div>

    <div class="container-fluid p-0">
        {{> block_myoverview/courses-view }}
    </div>
</div>
{{#js}}
require(
[
    'jquery',
    'block_myoverview/main',
],
function(
    $,
    Main
) {
    var root = $('#block-myoverview-{{uniqid}}');
    Main.init(root);
});
{{/js}}
