<div data-region="moodle-net-select">
    <div class="searchbar input-group" role="search">
        <label for="searchinput">
            <span class="sr-only">{{#str}} searchcourses, tool_moodlenet {{/str}}</span>
        </label>
        <input type="text"
               data-action="search"
               id="searchinput"
               class="form-control form-control-lg searchinput px-3 py-2"
               placeholder="{{#str}} search, core {{/str}}"
               name="search"
               autocomplete="off"
        >
        <div class="searchbar-append d-flex px-3">
            <button data-action="search">Search</button>
        </div>
    </div>
    <div class="searchresultscontainer" data-region="search-results-container" aria-live="polite"></div>
    <div data-region="mnet-courses"></div>
</div>
