<div data-region="moodle-net">
    <div class="overlay-icon-container d-none" data-region="spinner"></div>
    <img class="w-25 mb-4" src="{{{img}}}">
    <p>{{#str}} instancedescription, tool_moodlenet {{/str}}</p>
    <button class="btn btn-secondary d-block w-50 mx-auto mt-5 mb-3"
            data-action="browse"
    >
        {{#str}} browsemoodlenet, tool_moodlenet {{/str}}
    </button>
    <h5 class="text-center text-uppercase">{{#str}} or, tool_moodlenet {{/str}}</h5>
    <div id="mnet-instance-form-{{uniqid}}" data-region="mnet-form">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <div class="input-group w-50 mx-auto my-3">
            <input type="text"
                   class="form-control"
                   data-var="mnet-link"
                   placeholder="{{#str}} instanceplaceholder, tool_moodlenet {{/str}}"
                   aria-label="{{#str}} aria:enterprofile, tool_moodlenet {{/str}}"
                   autocomplete="off"
            >
            <div class="input-group-append">
                <button class="btn btn-outline-secondary"
                        data-action="submit" id="button-addon2"
                >
                    {{#str}} browse, tool_moodlenet {{/str}}
                </button>
            </div>
        </div>
    </div>
    <p class="text-center">{{#str}} forminfo, tool_moodlenet {{/str}}</p>
</div>
